<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect width="1200" height="630" fill="#0a0a0f"/>
  <rect x="0" y="0" width="1200" height="630" fill="url(#grid)" opacity="0.05"/>
  <defs>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#ffffff" stroke-width="0.5"/>
    </pattern>
  </defs>
  <!-- Left accent bar -->
  <rect x="80" y="180" width="4" height="260" fill="#f59e0b"/>
  <!-- Main title -->
  <text x="110" y="290" font-family="Arial, sans-serif" font-size="58" font-weight="bold" fill="#ffffff">Triple Output DC</text>
  <text x="110" y="360" font-family="Arial, sans-serif" font-size="58" font-weight="bold" fill="#ffffff">Power Supply</text>
  <!-- Subtitle -->
  <text x="110" y="410" font-family="Arial, sans-serif" font-size="28" fill="#f59e0b">Precision Lab Instruments · eTM-DM Series</text>
  <!-- Domain -->
  <text x="110" y="570" font-family="Arial, sans-serif" font-size="20" fill="#4b5563">tripleoutputdcpowersupply.com</text>
  <!-- Decorative voltage display boxes -->
  <rect x="820" y="160" width="170" height="90" rx="4" fill="#1a1a2e" stroke="#374151" stroke-width="1"/>
  <text x="905" y="198" font-family="monospace" font-size="14" fill="#6b7280" text-anchor="middle">CH1</text>
  <text x="905" y="235" font-family="monospace" font-size="32" font-weight="bold" fill="#f59e0b" text-anchor="middle">30.00V</text>
  <rect x="820" y="270" width="170" height="90" rx="4" fill="#1a1a2e" stroke="#374151" stroke-width="1"/>
  <text x="905" y="308" font-family="monospace" font-size="14" fill="#6b7280" text-anchor="middle">CH2</text>
  <text x="905" y="345" font-family="monospace" font-size="32" font-weight="bold" fill="#f59e0b" text-anchor="middle">-30.00V</text>
  <rect x="820" y="380" width="170" height="90" rx="4" fill="#1a1a2e" stroke="#374151" stroke-width="1"/>
  <text x="905" y="418" font-family="monospace" font-size="14" fill="#6b7280" text-anchor="middle">CH3</text>
  <text x="905" y="455" font-family="monospace" font-size="32" font-weight="bold" fill="#34d399" text-anchor="middle">5.00V</text>
</svg>
